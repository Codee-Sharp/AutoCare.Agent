APP_ENV=development
APP_AUTH_TOKEN=local-development-token
COMPOSER_BASE_URL=https://api-for-cursor.standardagents.ai/opencode/v1
# Required. Keep the real value only in the ignored local .env or a secret store.
COMPOSER_API_KEY=
COMPOSER_MODEL=composer-2.5
COMPOSER_TIMEOUT_SECONDS=10
MAX_MESSAGE_LENGTH=4000
LOG_LEVEL=INFO
CRISIS_GUIDANCE_CODE=contact_emergency_services
